{
  "id": "tinaide.lsp.java",
  "name": "Java Language Support (JDTLS)",
  "version": "1.0.0",
  "type": "lsp",
  "author": {
    "name": "TinaIDE"
  },
  "description": "Provides Java language intelligence utilizing Eclipse JDTLS and OpenJDK 17.",
  "contributions": {
    "languageServers": [
      {
        "id": "jdtls",
        "name": "Eclipse JDTLS",
        "languages": ["java"],
        "fileExtensions": ["java"],
        "runtime": {
          "type": "jvm",
          "minVersion": "17"
        },
        "server": {
          "type": "stdio",
          "command": "jdtls"
        }
      }
    ],
    "toolchains": [
      {
        "id": "openjdk-17",
        "name": "OpenJDK 17",
        "type": "system",
        "packagesByManager": {
          "apk": ["openjdk17"],
          "apt": ["openjdk-17-jdk-headless"]
        },
        "verifyCommand": "java -version",
        "verifyPattern": "17\\."
      },
      {
        "id": "jdtls",
        "name": "Eclipse JDTLS System Package",
        "type": "system",
        "packagesByManager": {
          "apk": ["jdtls"],
          "apt": ["jdtls"]
        },
        "verifyCommand": "jdtls --version"
      }
    ]
  }
}
