<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Remote LSP uses ws://host:port today, including LAN hosts configured by the user.
        Keep cleartext enabled at the platform layer so that feature remains usable.
        Sensitive server config responses are still protected by Release HMAC verification.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
